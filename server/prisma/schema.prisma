// Prisma schema for the Danish learning app.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev; the debian target matches the Docker runtime
  // image (node:22-slim / Debian bookworm + OpenSSL 3) used in production.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  xpTotal      Int      @default(0) @map("xp_total")
  createdAt    DateTime @default(now()) @map("created_at")

  progress    UserCardProgress[]
  cards       Card[]              @relation("UserCards")
  decks       Deck[]              @relation("UserDecks")
  activity    DailyActivity[]
  resetTokens PasswordResetToken[]
  achievements EarnedAchievement[]

  @@map("users")
}

// A badge the user has unlocked (see server/src/utils/achievements.js for the
// catalogue of keys). Rows are created once and never removed — achievements
// are permanent even if the triggering review is later undone.
model EarnedAchievement {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String
  earnedAt  DateTime @default(now()) @map("earned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("earned_achievements")
}

// A password-reset link's token is hashed at rest (tokenHash) so a leaked DB
// dump can't be used to reset accounts; only the raw token in the emailed
// link can match it.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Deck {
  id          String   @id @default(uuid())
  name        String
  category    String // "vocab" | "grammar" | "listening"
  description String?
  language    String   @default("da") // ISO-ish code for the language being taught, e.g. "da"
  ownerId     String?  @map("owner_id") // null = built-in/system deck, otherwise a user's custom deck
  createdAt   DateTime @default(now()) @map("created_at")

  owner User?  @relation("UserDecks", fields: [ownerId], references: [id], onDelete: Cascade)
  cards Card[]

  @@map("decks")
}

model Card {
  id              String   @id @default(uuid())
  deckId          String   @map("deck_id")
  targetText      String   @map("target_text") // the word/phrase in the language being learned (the deck's language)
  nativeText      String   @map("native_text") // the English meaning/translation
  exampleSentence String?  @map("example_sentence")
  cardType        String   @map("card_type") // "vocab" | "grammar" | "listening"
  ownerId         String?  @map("owner_id") // null = built-in/system card, otherwise a user's custom card
  createdAt       DateTime @default(now()) @map("created_at")

  deck     Deck               @relation(fields: [deckId], references: [id], onDelete: Cascade)
  owner    User?              @relation("UserCards", fields: [ownerId], references: [id], onDelete: Cascade)
  progress UserCardProgress[]

  @@index([deckId])
  @@map("cards")
}

// SM-2 spaced-repetition state, tracked per-user per-card.
model UserCardProgress {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  cardId         String    @map("card_id")
  easeFactor     Float     @default(2.5) @map("ease_factor")
  intervalDays   Int       @default(0) @map("interval_days")
  repetitions    Int       @default(0)
  dueDate        DateTime  @default(now()) @map("due_date")
  lastReviewedAt DateTime? @map("last_reviewed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, dueDate])
  @@map("user_card_progress")
}

// One row per user per day they did something (studied and/or practiced
// conversation) — used to compute streaks. Either count being nonzero marks
// the day as active; the dashboard exposes their sum as one "activity" number.
model DailyActivity {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  date         DateTime @db.Date
  reviews      Int      @default(0)
  chatMessages Int      @default(0) @map("chat_messages")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_activity")
}
