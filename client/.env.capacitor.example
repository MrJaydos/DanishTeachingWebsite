# Copy to client/.env.capacitor (gitignored) and fill in your real deployed
# domain before running `npm run build:capacitor`.
#
# The native app's web assets are bundled locally — there's no same-origin
# backend to proxy to like there is for the web/PWA build, so API calls need
# an absolute URL to wherever this app is actually deployed (Coolify).
VITE_API_BASE_URL=https://your-deployed-domain.example
