# ---------------------------------------------------------------------------
# Danish Learning App — environment variables
# Copy this file to `.env` for local docker-compose, or set these values in
# Coolify's "Environment Variables" UI when deploying.
# ---------------------------------------------------------------------------

# Port the app listens on (Coolify maps this). The container serves BOTH the
# REST API and the built React frontend on this single port.
PORT=8080

# PostgreSQL connection string.
#   - Local docker-compose: use the service hostname "db" (see docker-compose.yml).
#   - Coolify: point this at the Postgres database you create in Coolify.
DATABASE_URL=postgresql://danish:danish@db:5432/danish?schema=public

# Secret used to sign JWT session tokens. MUST be a long random string in
# production. Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# How long a login session (JWT) stays valid.
JWT_EXPIRES_IN=7d

# Node environment ("production" in Coolify, "development" locally if you like).
NODE_ENV=production

# Public origin of the deployed app, used to build links in emails (e.g. the
# password reset link). Set to your real domain in production.
APP_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# SMTP (used only for password-reset emails). Any SMTP provider works, e.g.:
#   - Gmail: smtp.gmail.com:587, your address as SMTP_USER, an "app password"
#     (Google Account > Security > App passwords) as SMTP_PASS.
#   - Resend / Brevo / SES etc: use the SMTP credentials they issue.
# If left blank, reset links are logged to the server console instead of
# emailed — handy for local dev, not for production.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Dansk <no-reply@dansk.app>

# ---------------------------------------------------------------------------
# Gemini API (used only for the "Practice" conversation chatbot). Get a free
# key at https://aistudio.google.com/apikey — no billing account required for
# the free tier. If left blank, the Practice page shows a "not configured
# yet" message instead of erroring.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# The variables below are only used by docker-compose for the local Postgres
# container. They are NOT needed in Coolify (Coolify manages its own Postgres).
# ---------------------------------------------------------------------------
POSTGRES_USER=danish
POSTGRES_PASSWORD=danish
POSTGRES_DB=danish
