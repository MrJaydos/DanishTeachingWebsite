# ---------------------------------------------------------------------------
# Danish Learning App — environment variables
# Copy this file to `.env` for local docker-compose, or set these values in
# Coolify's "Environment Variables" UI when deploying.
# ---------------------------------------------------------------------------

# Port the app listens on (Coolify maps this). The container serves BOTH the
# REST API and the built React frontend on this single port.
PORT=8080

# PostgreSQL connection string.
#   - Local docker-compose: use the service hostname "db" (see docker-compose.yml).
#   - Coolify: point this at the Postgres database you create in Coolify.
DATABASE_URL=postgresql://danish:danish@db:5432/danish?schema=public

# Secret used to sign JWT session tokens. MUST be a long random string in
# production. Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# How long a login session (JWT) stays valid.
JWT_EXPIRES_IN=7d

# Node environment ("production" in Coolify, "development" locally if you like).
NODE_ENV=production

# ---------------------------------------------------------------------------
# The variables below are only used by docker-compose for the local Postgres
# container. They are NOT needed in Coolify (Coolify manages its own Postgres).
# ---------------------------------------------------------------------------
POSTGRES_USER=danish
POSTGRES_PASSWORD=danish
POSTGRES_DB=danish
